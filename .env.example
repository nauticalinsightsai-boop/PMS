# Public URLs — always use the dev gateway (npm run dev → http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: https://www.pmstructure.com

# Legal / footer entity (optional — footer shows address/phone only when set)
# NEXT_PUBLIC_LEGAL_ENTITY_NAME=
# NEXT_PUBLIC_LEGAL_ENTITY_ADDRESS=
# NEXT_PUBLIC_CONTACT_PHONE=
# NEXT_PUBLIC_SUPPORT_EMAIL=support@pmstructure.com
# All legal/privacy/compliance mail routes to support@ (LEGAL_EMAIL deprecated)
# NEXT_PUBLIC_OG_IMAGE_PATH=/og/default.png
# Browser calls /api on :3000 (gateway → internal API on :3001)
NEXT_PUBLIC_API_URL=http://localhost:3000
# Server-side rewrites (marketing Next → public API process)
BACKEND_URL=http://localhost:3001

# Regional matrix Excel path (optional; default: i:\My Drive\Sample\PM_Structure_Regional_Availability_Matrix.xlsx)
# REGIONAL_MATRIX_XLSX_PATH=

# Postgres URI for npm run db:migrate (Supabase → Settings → Database → Connection string)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-....pooler.supabase.com:6543/postgres

# Stripe (backend checkout — omit for mock sessions in dev)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Dashboard (browser :3000/dashboard — internal apps on :5174 / :3002)
DASHBOARD_BACKEND_URL=http://localhost:3002
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_SITE_URL=http://localhost:3000

# Supabase — Project URL: https://YOUR_REF.supabase.co (Settings → API)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: allow admin@pms.os / admin in production (default: only in NODE_ENV=development)
# NEXT_PUBLIC_ALLOW_DEMO_LOGIN=true

# Optional (newer Supabase key format — not required for this codebase)
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=

# Pathway enrollment (marketing site — see docs/PATHWAY_ENROLLMENT_ENV.md)
# NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/XXXXXXXXXXX
# Flagship PMP consultation events (one Calendly URL per tier):
# NEXT_PUBLIC_CALENDLY_PATHWAY_PMP_FOUNDATION=https://calendly.com/booking-sh3ikhmabz/...
# NEXT_PUBLIC_CALENDLY_PATHWAY_PMP_PROFESSIONAL=https://calendly.com/booking-sh3ikhmabz/...
# NEXT_PUBLIC_CALENDLY_PATHWAY_PMP_MASTERY=https://calendly.com/booking-sh3ikhmabz/...
# List all 51 keys: npm run print:pathway-calendly-env
