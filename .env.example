# Public site (Next.js — default dev port 3050 if 3000 is taken by another app)
NEXT_PUBLIC_SITE_URL=http://localhost:3050
BACKEND_URL=http://localhost:3001

# Dashboard UI (Next.js :5174)
DASHBOARD_BACKEND_URL=http://localhost:3002
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:5174

# Supabase — Project URL: https://YOUR_REF.supabase.co (Settings → API)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: allow admin@pms.os / admin in production (default: only in NODE_ENV=development)
# NEXT_PUBLIC_ALLOW_DEMO_LOGIN=true

# Optional (newer Supabase key format — not required for this codebase)
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=
