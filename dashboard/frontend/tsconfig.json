{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "**/*.js", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "lib/interactions/admin-audit.ts",
    "lib/interactions/admin-guard.ts",
    "lib/interactions/broadcast.ts",
    "lib/interactions/engagement-bridge.ts",
    "lib/interactions/export.ts",
    "lib/interactions/query.ts",
    "lib/interactions/rate-limit.ts",
    "lib/interactions/payload-sanitize.ts",
    "lib/interactions/request-ip.ts",
    "lib/interactions/request-ip.test.ts",
    "lib/interactions/schema.ts",
    "lib/interactions/service.ts",
    "lib/interactions/sheets-api-response.ts",
    "lib/interactions/sheets-sync.ts",
    "lib/interactions/sync-status.ts",
    "lib/interactions/submit-public.ts",
    "lib/interactions/google-sheets.ts"
  ]
}
